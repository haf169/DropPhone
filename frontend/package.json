    "cap:android": "npx cap run android",
    "cap:ios": "npx cap run ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/motion": "^6.0.1",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^8",
    "eslint-config-next": "^15.3.0",
    "typescript": "^5"
  }
