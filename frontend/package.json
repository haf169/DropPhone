{
  "name": "dropphone-frontend",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "get-ip": "node scripts/get-local-ip.js",
