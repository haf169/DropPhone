# DropPhone - Environment Variables
# Copy file này thành .env và điền giá trị thực

# ================================
# Application
# ================================
NODE_ENV=development
PORT=3001

# ================================
# Database (PostgreSQL)
# ================================
DB_HOST=db          # Tên service trong docker-compose
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=dropphone_secret_change_me
DB_DATABASE=dropphone

# ================================
# API URLs
# ================================
# URL public của backend (dùng để build URL file audio)
# Khi test trên điện thoại thật: đổi localhost thành IP máy tính
# Ví dụ: http://192.168.1.100:3001
API_BASE_URL=http://localhost:3001

# URL API cho Next.js frontend gọi
# NEXT_PUBLIC_ prefix để expose ra client-side
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ================================
# Mobile / Capacitor Config
# ================================
# Khi build cho điện thoại thật, thay localhost bằng IP LAN của máy tính
# Ví dụ: NEXT_PUBLIC_API_URL=http://192.168.1.100:3001/api
#
# Tìm IP LAN:
#   Windows: ipconfig (tìm IPv4 Address)
#   Mac/Linux: ifconfig | grep inet
